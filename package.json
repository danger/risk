{
  "name": "risk",
  "version": "0.0.5",
  "description": "A modernized, minimal Danger JS for GitHub",
  "license": "MIT",
  "author": "Orta Therox <orta.therox@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/danger/risk.git"
  },
  "homepage": "https://github.com/danger/risk#readme",
  "bugs": {
    "url": "https://github.com/danger/risk/issues"
  },
  "keywords": [
    "danger",
    "code-review",
    "github",
    "pull-request",
    "ci",
    "linting"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "danger": "./dist/cli/danger.js"
  },
  "files": [
    "dist",
    "index.d.ts",
    "danger.d.ts"
  ],
  "packageManager": "yarn@4.12.0",
  "engines": {
    "node": ">=22.6.0"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "release": "node --experimental-strip-types scripts/release.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@octokit/rest": "^21.1.1",
    "parse-diff": "^0.11.1",
    "picomatch": "^4.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/picomatch": "^3.0.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
